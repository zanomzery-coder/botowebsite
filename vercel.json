{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "api/download.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/download", "dest": "/api/download.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
